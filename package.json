    "e2e": "start-server-and-test build-and-start:prod http://localhost:4173 cypress:run"
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.0",
